---
import Layout from "../layouts/Layout.astro";
import projects from "../data/projects.json";
import { skills, experience, education, contact } from "../data/info.js";

import { Icon } from "astro-icon/components";

const categories = ["all", ...new Set(projects.map((p) => p.category))];

const skillGroups = [
  { icon: "lucide:code-2", title: "Languages", tags: skills.languages },
  {
    icon: "lucide:monitor-smartphone",
    title: "Frontend",
    tags: skills.frontend,
  },
  { icon: "lucide:server-cog", title: "Backend", tags: skills.backend },
  { icon: "lucide:database", title: "Databases", tags: skills.databases },
  { icon: "lucide:wrench", title: "Tools & Platforms", tags: skills.tools },
  {
    icon: "lucide:network",
    title: "Infrastructure",
    tags: skills.infrastructure,
  },
  {
    icon: "lucide:shield-check",
    title: "Cybersecurity",
    tags: skills.cybersecurity,
    security: true,
  },
  { icon: "lucide:bar-chart-3", title: "Analytics", tags: skills.analytics },
];
---

<Layout>
  <!-- ═══════════════════════════════════════════════
       NAV
  ═══════════════════════════════════════════════ -->
  <nav>
    <div class="container">
      <div class="nav-inner">
        <a href="#hero" class="nav-logo">RK<span>.</span></a>

        <ul class="nav-links">
          <li><a href="#about">About</a></li>
          <li><a href="#skills">Skills</a></li>
          <li><a href="#projects">Projects</a></li>
          <li><a href="#experience">Experience</a></li>
          <li><a href="#contact" class="nav-cta">Hire Me</a></li>
        </ul>

        <button class="hamburger" aria-label="Menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════ -->
  <section id="hero">
    <div class="hero-grid-bg"></div>
    <div class="hero-glow"></div>

    <div class="container">
      <div class="hero-content">
        <div class="hero-eyebrow">
          <span class="dot"></span>
          Available for work
        </div>

        <h1 class="hero-name">
          <span class="line-1">RAJ</span><br />
          <span class="line-2">KUSHWAHA</span>
        </h1>

        <p class="hero-title">
          Full Stack Developer
          <span class="pipe">|</span>
          Security-Focused Architecture
          <span class="pipe">|</span>
          Thane, MH
        </p>

        <p class="hero-desc">
          I build performant, secure web applications — from scalable Node.js
          APIs and headless storefronts to hardened server infrastructure.
          Currently expanding into cybersecurity and offensive tooling.
        </p>

        <div class="hero-actions">
          <a href="#projects" class="btn-primary">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
            >
            View My Work
          </a>
          <a href={`mailto:${contact.email}`} class="btn-secondary">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path
                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path><polyline points="22,6 12,12 2,6"></polyline></svg
            >
            Get In Touch
          </a>
        </div>

        <div class="hero-stats">
          <div>
            <span class="stat-num">10+</span>
            <span class="stat-label">Production Apps</span>
          </div>
          <div>
            <span class="stat-num">3+</span>
            <span class="stat-label">Years Experience</span>
          </div>
          <div>
            <span class="stat-num">15+</span>
            <span class="stat-label">Technologies</span>
          </div>
        </div>
      </div>
    </div>

    <div class="hero-scroll">
      <div class="scroll-line"></div>
      <span>Scroll</span>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       ABOUT
  ═══════════════════════════════════════════════ -->
  <section id="about">
    <div class="container">
      <div class="about-grid">
        <div class="about-text fade-up">
          <p class="section-label">About Me</p>
          <h2 class="section-title" style="margin-bottom: 2rem;">
            Building Secure,<br />Scalable Systems
          </h2>
          <p>
            I'm a <strong>Full Stack Developer</strong> based in Thane, Maharashtra,
            with a focus on building backend architectures that are not just functional
            — but defensible. I approach every project with a security-first mindset.
          </p>
          <p>
            My work spans from deploying <strong
              >headless e-commerce platforms</strong
            > with MedusaJS and Next.js, to configuring VPS infrastructure (Nginx,
            PM2, DNS, SMTP), to building automation pipelines that cut manual effort
            by over 80%.
          </p>
          <p>
            I'm actively growing my knowledge in <strong>cybersecurity</strong> —
            working with tools like Burp Suite, OWASP ZAP, and Nmap to understand
            the attacker's perspective and build systems that hold up to scrutiny.
          </p>
          <div
            style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-top:1.75rem;"
          >
            <a
              href={contact.github}
              target="_blank"
              rel="noopener"
              class="btn-secondary">GitHub →</a
            >
            <a
              href={contact.linkedin}
              target="_blank"
              rel="noopener"
              class="btn-secondary">LinkedIn →</a
            >
            <!-- <a href={contact.website} target="_blank" rel="noopener" class="btn-secondary">Live Site →</a> -->
          </div>
        </div>

        <div class="about-terminal fade-up" style="transition-delay:0.15s">
          <div class="terminal-bar">
            <div class="t-dot red"></div>
            <div class="t-dot yellow"></div>
            <div class="t-dot green"></div>
            <span class="terminal-title">raj@portfolio ~ zsh</span>
          </div>
          <div class="terminal-body">
            <div class="t-line">
              <span class="t-prompt">❯</span><span class="t-cmd">whoami</span>
            </div>
            <div class="t-line t-out green">raj_kushwaha</div>
            <br />
            <div class="t-line">
              <span class="t-prompt">❯</span><span class="t-cmd"
                >cat profile.json</span
              >
            </div>
            <div class="t-line t-out">&#123;</div>
            <div class="t-line t-out">
              &nbsp;&nbsp;"role": "Full Stack Developer",
            </div>
            <div class="t-line t-out">
              &nbsp;&nbsp;"location": "Thane, MH, IN",
            </div>
            <div class="t-line t-out">
              &nbsp;&nbsp;"focus": ["Backend", "Security"],
            </div>
            <div class="t-line t-out">&nbsp;&nbsp;"available": true,</div>
            <div class="t-line t-out">
              &nbsp;&nbsp;"email": "kushwaharaj903@gmail.com"
            </div>
            <div class="t-line t-out">&#125;</div>
            <br />
            <div class="t-line">
              <span class="t-prompt">❯</span><span class="t-cmd"
                >ls ./skills/security</span
              >
            </div>
            <div class="t-line t-out">
              nmap&nbsp; nikto&nbsp; owasp-zap&nbsp; burp-suite
            </div>
            <br />
            <div class="t-line">
              <span class="t-prompt">❯</span><span class="t-cmd"
                >git log --oneline -3</span
              >
            </div>
            <div class="t-line t-out">
              a3f9c12 feat: add rate limiting middleware
            </div>
            <div class="t-line t-out">b12de45 fix: harden CORS policy</div>
            <div class="t-line t-out">c98fa01 chore: security audit pass</div>
            <br />
            <div class="t-line">
              <span class="t-prompt">❯</span><span class="t-cmd"
                ><span class="t-cursor"></span></span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SKILLS
  ═══════════════════════════════════════════════ -->
  <section id="skills">
    <div class="container">
      <div class="fade-up">
        <p class="section-label">Technical Stack</p>
        <h2 class="section-title">Skills &amp; Tools</h2>
      </div>

      <div class="skills-grid">
        {
          skillGroups.map((group, i) => (
            <div
              class={`skill-card fade-up`}
              style={`transition-delay:${i * 0.05}s`}
            >
              <div class="skill-card-header">
                {/* <div class="skill-icon">{group.icon}</div> */}
                <Icon name={group.icon} class="w-5 h-5" />
                <div class="skill-card-title">{group.title}</div>
              </div>
              <div class="skill-tags">
                {group.tags.map((tag) => (
                  <span class={`tag${group.security ? " security" : ""}`}>
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       PROJECTS
  ═══════════════════════════════════════════════ -->
  <section id="projects">
    <div class="container">
      <div class="fade-up">
        <p class="section-label">Selected Work</p>
        <h2 class="section-title">Projects</h2>
      </div>

      <div class="projects-filter fade-up" style="transition-delay:0.1s">
        {
          categories.map((cat) => (
            <button
              class={`filter-btn${cat === "all" ? " active" : ""}`}
              data-filter={cat}
            >
              {cat}
            </button>
          ))
        }
      </div>

      <div class="projects-grid">
        {
          projects.map((project, i) => (
            <article
              class={`project-card fade-up${project.featured ? " featured" : ""}`}
              style={`transition-delay:${i * 0.08}s`}
              data-category={project.category}
            >
              <div class="project-number">
                {String(i + 1).padStart(2, "0")} — {project.year}
              </div>

              <h3 class="project-title">{project.title}</h3>
              <p class="project-desc">{project.description}</p>

              <div class="project-tags">
                {project.tags.slice(0, 5).map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>

              <div class="project-links">
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener"
                  class="project-link"
                >
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22" />
                  </svg>
                  GitHub
                </a>
                {project.live && (
                  <a
                    href={project.live}
                    target="_blank"
                    rel="noopener"
                    class="project-link"
                  >
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6" />
                      <polyline points="15 3 21 3 21 9" />
                      <line x1="10" y1="14" x2="21" y2="3" />
                    </svg>
                    Live
                  </a>
                )}
                <span class="tag" style="margin-left:auto">
                  {project.category}
                </span>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       EXPERIENCE & EDUCATION
  ═══════════════════════════════════════════════ -->
  <section id="experience">
    <div class="container">
      <div class="fade-up">
        <p class="section-label">Background</p>
        <h2 class="section-title">Experience &amp;<br />Education</h2>
      </div>

      <div class="exp-grid">
        <!-- Timeline -->
        <div class="exp-timeline fade-up" style="transition-delay:0.1s">
          {
            experience.map((exp) => (
              <div class="exp-item">
                <div class="exp-dot" />
                <div class="exp-meta">
                  {exp.period} · {exp.location}
                </div>
                <div class="exp-role">{exp.role}</div>
                <div class="exp-company">{exp.company}</div>
                <p style="font-size:0.82rem;color:var(--text-muted);margin-top:0.75rem;font-weight:300;line-height:1.8;">
                  {exp.description}
                </p>
                {/* <ul class="highlights" style="margin-top:1rem;">
                {exp.highlights.map(h => (
                  <li>{h}</li>
                ))}
              </ul> */}
              </div>
            ))
          }
        </div>

        <!-- Education + Extra Cards -->
        <div
          class="fade-up"
          style="transition-delay:0.2s;display:flex;flex-direction:column;gap:1.5rem;"
        >
          {
            education.map((edu) => (
              <div class="edu-card">
                <div class="edu-label">// Education</div>
                <div class="edu-degree">{edu.degree}</div>
                <div class="edu-institution">{edu.institution}</div>
                <div class="edu-period">{edu.period}</div>
                <p style="font-size:0.82rem;color:var(--text-muted);font-weight:300;line-height:1.7;">
                  {/* {edu.description} */}
                </p>
              </div>
            ))
          }

          <!-- Currently Learning -->
          <div class="edu-card">
            <div class="edu-label">// Currently Learning</div>
            <div class="edu-degree">
              Cybersecurity &amp; Penetration Testing
            </div>
            <div class="edu-period">2026 – Present</div>
            <div class="skill-tags" style="margin-top:1rem;">
              <span class="tag security">Burp Suite</span>
              <span class="tag security">OWASP Top 10</span>
              <span class="tag security">Network Scanning</span>
              <span class="tag security">Web App Pentesting</span>
            </div>
          </div>

          <!-- Side note card -->
          <div
            class="edu-card"
            style="background: linear-gradient(135deg, rgba(0,255,136,0.04), transparent); border-color: rgba(0,255,136,0.2);"
          >
            <div class="edu-label" style="color:var(--green)"># philosophy</div>
            <p
              style="font-size:0.85rem;line-height:1.9;color:var(--text-dim);font-weight:300;font-style:italic;"
            >
              "Security is not something added later — it begins with how
              systems are designed. I build applications with performance,
              scalability, and security in mind."
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       CONTACT
  ═══════════════════════════════════════════════ -->
  <section id="contact">
    <div class="container">
      <div class="fade-up">
        <p class="section-label">Let's Work Together</p>
        <h2 class="section-title">Get In Touch</h2>
      </div>

      <div class="contact-grid">
        <div class="fade-up" style="transition-delay:0.1s">
          <p class="contact-desc">
            Looking for a developer who understands both the product and the
            threat landscape? I'm open to freelance projects, full-time roles,
            and security consulting gigs.
          </p>

          <div class="contact-links">
            <a href={`mailto:${contact.email}`} class="contact-link-item">
              <!-- <div class="contact-link-icon">✉️</div> -->
              <div class="contact-link-icon">
                <Icon name="lucide:mail" size={18} />
              </div>
              <div class="contact-link-text">
                <span class="contact-link-label">Email</span>
                {contact.email}
              </div>
            </a>
            <a href={`tel:${contact.phone}`} class="contact-link-item">
              <div class="contact-link-icon">
                <Icon name="lucide:phone" size={18} />
              </div>
              <div class="contact-link-text">
                <span class="contact-link-label">Phone</span>
                {contact.phone}
              </div>
            </a>
            <a
              href={contact.github}
              target="_blank"
              rel="noopener"
              class="contact-link-item"
            >
              <div class="contact-link-icon">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  ><path
                    d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                  ></path></svg
                >
              </div>
              <div class="contact-link-text">
                <span class="contact-link-label">GitHub</span>
                github.com/rajk5266
              </div>
            </a>
            <a
              href={contact.linkedin}
              target="_blank"
              rel="noopener"
              class="contact-link-item"
            >
            <div class="contact-link-icon">
  <Icon name="lucide:linkedin" size={18} />
</div>
              <div class="contact-link-text">
                <span class="contact-link-label">LinkedIn</span>
                linkedin.com/in/rajkushwaha903
              </div>
            </a>
            <div class="contact-link-item" style="cursor:default;">
            <div class="contact-link-icon">
  <Icon name="lucide:map-pin" size={18} />
</div>
              <div class="contact-link-text">
                <span class="contact-link-label">Location</span>
                {contact.location}, India
              </div>
            </div>
          </div>
        </div>

        <div class="contact-form-card fade-up" style="transition-delay:0.2s">
          <div class="edu-label" style="margin-bottom:1.25rem;">
            // Send a Message
          </div>
          <form
            class="contact-form"
            action={`mailto:${contact.email}`}
            method="POST"
          >
            <div class="form-group">
              <label class="form-label" for="name">Your Name</label>
              <input
                class="form-input"
                type="text"
                id="name"
                name="name"
                placeholder="John Doe"
                required
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="email">Email Address</label>
              <input
                class="form-input"
                type="email"
                id="email"
                name="email"
                placeholder="john@example.com"
                required
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="subject">Subject</label>
              <input
                class="form-input"
                type="text"
                id="subject"
                name="subject"
                placeholder="Project Inquiry"
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="message">Message</label>
              <textarea
                class="form-textarea"
                id="message"
                name="message"
                placeholder="Tell me about your project..."
                required></textarea>
            </div>
            <button type="submit" class="form-submit">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FOOTER
  ═══════════════════════════════════════════════ -->
  <footer>
    <div class="container">
      <div class="footer-inner">
        <p class="footer-copy">
          © 2024 <span>Raj Kushwaha</span>. Built with AstroJS. Designed for
          performance.
        </p>
        <div class="footer-social">
          <a
            href={contact.github}
            target="_blank"
            rel="noopener"
            aria-label="GitHub"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path></svg
            >
          </a>
          <a
            href={contact.linkedin}
            target="_blank"
            rel="noopener"
            aria-label="LinkedIn"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path></svg
            >
          </a>
